{
    "name": "mishna-text",
    "version": "1.0.1",
    "description": "Hebrew and English text for all Mishna, organized by seder, tractate, perek, and mishna",
    "type": "module",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./zeraim": "./data/zeraim.json",
        "./moed": "./data/moed.json",
        "./nashim": "./data/nashim.json",
        "./nezikin": "./data/nezikin.json",
        "./kodashim": "./data/kodashim.json",
        "./tahorot": "./data/tahorot.json"
    },
    "files": [
        "dist",
        "data"
    ],
    "scripts": {
        "build": "tsup",
        "download": "tsx scripts/download.ts",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "mishna",
        "mishnah",
        "torah",
        "jewish",
        "hebrew",
        "sefaria"
    ],
    "license": "MIT",
    "devDependencies": {
        "@types/node": "^25.9.1",
        "tsup": "^8.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.0.0"
    }
}
